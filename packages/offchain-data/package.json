{
  "name": "@palladxyz/offchain-data",
  "description": "Off-chain data fetching services.",
  "type": "module",
  "version": "1.0.0",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
