{
  "name": "@palladxyz/multi-chain-core",
  "version": "0.0.1",
  "type": "module",
  "description": "Multi-Chain Core Package SDK for Pallad",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist",
    "dev": "bun run build ---watch",
    "test:unit": "vitest run",
    "cleanup": "rimraf node_modules dist .turbo"
  },
  "dependencies": {
    "@palladxyz/util": "workspace:*",
    "@palladxyz/mina-core": "workspace:*",
    "@palladxyz/mina-graphql": "workspace:*"
  },
  "devDependencies": {
    "@palladxyz/common": "workspace:*",
    "@types/mocha": "^10.0.1"
  }
}
